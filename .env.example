# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude API
ANTHROPIC_API_KEY=

# QuickBooks
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
# Must match the redirect URI registered in Intuit Developer Portal.
# Local dev: http://localhost:3000/api/auth/callback/quickbooks
# Production: https://dockett.app/api/auth/callback/quickbooks
QBO_REDIRECT_URI=http://localhost:3000/api/auth/callback/quickbooks
QBO_ENVIRONMENT=sandbox

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs (three-tier pricing: $29/$59/$99)
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_ANNUAL_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_GROWTH_MONTHLY_PRICE_ID=
STRIPE_GROWTH_ANNUAL_PRICE_ID=
STRIPE_DESIGN_PARTNER_COUPON_ID=

# Encryption (for OAuth tokens at rest -- 32 bytes, hex-encoded)
ENCRYPTION_KEY=
# Optional: previous key for rotation. Only needed while rotating keys.
# Set this to the old ENCRYPTION_KEY value during rotation, then remove after migration.
ENCRYPTION_KEY_PREVIOUS=

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry Build (for source map uploads — optional in dev)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Resend (transactional email)
RESEND_API_KEY=

# Vercel Cron (lifecycle emails — set in Vercel dashboard)
CRON_SECRET=

# Xero OAuth2
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# Must match the redirect URI registered in Xero Developer Portal.
# Local dev: http://localhost:3000/api/auth/callback/xero
# Production: https://dockett.app/api/auth/callback/xero
XERO_REDIRECT_URI=http://localhost:3000/api/auth/callback/xero
# Xero tenant ID — set only for sandbox scripts. In production, this is
# fetched dynamically via the /connections endpoint after OAuth.
XERO_TENANT_ID=
# Xero access/refresh tokens (populated by scripts/sandbox/xero-auth.ts — not committed)
# XERO_ACCESS_TOKEN=
# XERO_REFRESH_TOKEN=
