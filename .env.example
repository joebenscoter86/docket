# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude API
ANTHROPIC_API_KEY=

# QuickBooks
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
# Must match the redirect URI registered in Intuit Developer Portal.
# Local dev: http://localhost:3000/api/auth/callback/quickbooks
# Production: https://dockett.app/api/auth/callback/quickbooks
QBO_REDIRECT_URI=http://localhost:3000/api/auth/callback/quickbooks
QBO_ENVIRONMENT=sandbox

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_GROWTH_PRICE_ID=           # Stripe Price ID for $99/mo Growth plan

# Encryption (for OAuth tokens at rest — 32 bytes, hex-encoded)
ENCRYPTION_KEY=

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
